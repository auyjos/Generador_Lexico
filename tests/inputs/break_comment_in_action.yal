(* break_comment_in_action.yal
   ROMPE: las acciones contienen comentarios (* ... *) que se filtran
   al nombre del token, generando identificadores Java inválidos como:
       TokenType.(* acción *) return FOO
*)

let digit  = ['0'-'9']
let letter = ['a'-'z''A'-'Z']

rule tokens =
    digit+                        { (* número *) return NUM }
  | letter (letter | digit)*     { return ID (* identificador *) }
  | '+'                           { return PLUS (* operador *) }
  | [' ' '\t' '\n']+             { (* skip *) }
