(* ejemplo oficial de yalex.md *)

{
import myToken
}

rule gettoken =
    [' ' '\t'] { return lexbuf }
  | ['\n'] { return EOL }
  | ['0'-'9']+ { return int(lxm) }
  | '+' { return PLUS }
  | '-' { return MINUS }
  | '*' { return TIMES }
  | '/' { return DIV }
  | '(' { return LPAREN }
  | ')' { return RPAREN }
  | eof { raise('Fin de buffer') }
